# Copy this file to .env.local in the app that needs it (e.g. apps/web/.env.local)
# and fill in real values. Never commit .env.local.

# --- Clerk (required in phase 1) -----------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Phase 2 and later (optional in phase 1) -----------------------------
# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/podviva

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Trigger.dev
TRIGGER_SECRET_KEY=

# Stripe (premium API entitlements)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Model providers
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Slack webhook for publish notifications
SLACK_WEBHOOK_URL=
